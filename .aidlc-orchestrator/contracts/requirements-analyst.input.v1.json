{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "requirements-analyst.input.v1",
  "title": "Requirements Analyst — Input Contract (v1)",
  "type": "object",
  "required": [
    "run_id",
    "stage_id",
    "user_request",
    "predecessor_artifacts",
    "workspace_state",
    "skills_required",
    "skill_paths_resolved"
  ],
  "properties": {
    "run_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "stage_id": { "const": "requirements-analyst" },
    "user_request": { "type": "string", "minLength": 1 },
    "predecessor_artifacts": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "MUST include the workspace-scout output handoff path"
    },
    "workspace_state": {
      "type": "object",
      "required": ["project_type", "existing_code", "next_phase"],
      "properties": {
        "project_type": { "type": "string", "enum": ["greenfield", "brownfield"] },
        "existing_code": { "type": "boolean" },
        "programming_languages": { "type": "array", "items": { "type": "string" } },
        "build_system": { "type": "string" },
        "project_structure": { "type": "string" },
        "workspace_root": { "type": "string" },
        "next_phase": { "type": "string" },
        "reverse_engineering_artifacts_present": { "type": "boolean" }
      }
    },
    "skills_required": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3,
      "description": "Must include idea-refine, spec-driven-development, using-agent-skills",
      "default": ["idea-refine", "spec-driven-development", "using-agent-skills"]
    },
    "skill_paths_resolved": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "budget": {
      "type": "object",
      "properties": {
        "tokens_max": { "type": "integer", "minimum": 1 },
        "wall_clock_max_min": { "type": "number", "minimum": 0 },
        "retries_max": { "type": "integer", "minimum": 0 }
      }
    },
    "gates": {
      "type": "array",
      "items": { "type": "string" },
      "default": ["require_human_approval"]
    },
    "context_pointers": { "type": "array", "items": { "type": "string" }, "default": [] },
    "locks_required": { "type": "array", "items": { "type": "string" }, "default": [] },
    "depth_override": {
      "type": "string",
      "enum": ["minimal", "standard", "comprehensive"],
      "description": "Set by Cost Governor when budget is below threshold. Agent must honor this over its own classification result."
    },
    "model_override": {
      "type": "string",
      "enum": ["sonnet", "opus", "haiku"],
      "description": "Model to use for this stage. Overrides tool default. Set by orchestrator from budgets/default.yaml."
    }
  },
  "additionalProperties": false
}
