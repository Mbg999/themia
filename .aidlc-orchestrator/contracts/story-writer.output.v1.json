{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "story-writer.output.v1",
  "title": "Story Writer — Output Contract (v1)",
  "type": "object",
  "required": ["status", "artifacts", "audit_entries", "skill_compliance"],
  "properties": {
    "status": { "type": "string", "enum": ["complete", "blocked", "failed", "needs_human"] },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind"],
        "properties": {
          "path": { "type": "string" },
          "kind": { "type": "string", "enum": ["spec", "questions", "doc"] },
          "hash": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "audit_entries": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
    "skill_compliance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["skill", "status", "evidence"],
        "properties": {
          "skill": { "type": "string" },
          "status": { "type": "string", "enum": ["PASS", "FAIL", "N/A"] },
          "evidence": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      },
      "minItems": 2
    },
    "cost": { "type": "object" },
    "needs_user_input": { "type": "boolean" },
    "questions_artifact_path": { "type": "string" },
    "story_count": { "type": "integer", "minimum": 0 },
    "persona_count": { "type": "integer", "minimum": 0 },
    "emitted_knowledge": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "title", "body"],
        "properties": {
          "kind": { "type": "string", "enum": ["pattern", "adr", "antipattern", "lesson"] },
          "title": { "type": "string", "minLength": 1 },
          "body": { "type": "string", "minLength": 1 },
          "tags": { "type": "array", "items": { "type": "string" }, "default": [] },
          "related_artifacts": { "type": "array", "items": { "type": "string" }, "default": [] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.8 }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "conflicts_detected": { "type": "array", "default": [] },
    "locks_to_release": { "type": "array", "items": { "type": "string" }, "default": [] }
  },
  "additionalProperties": false
}
