{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "requirements-analyst.output.v1",
  "title": "Requirements Analyst — Output Contract (v1)",
  "type": "object",
  "required": [
    "status",
    "artifacts",
    "audit_entries",
    "skill_compliance",
    "depth"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["complete", "blocked", "failed", "needs_human"]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind"],
        "properties": {
          "path": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["source", "test", "doc", "config", "spec", "plan", "questions", "state"]
          },
          "hash": { "type": "string" }
        },
        "additionalProperties": false
      },
      "description": "MUST include requirements.md (kind: spec). MUST include requirement-verification-questions.md (kind: questions) unless trivially clear."
    },
    "audit_entries": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "skill_compliance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["skill", "status", "evidence"],
        "properties": {
          "skill": { "type": "string" },
          "status": { "type": "string", "enum": ["PASS", "FAIL", "N/A"] },
          "evidence": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      },
      "minItems": 4,
      "description": "Must contain entries for idea-refine, spec-driven-development, using-agent-skills, and requirements-intelligence (coverage-map + signal-score + techniques-applied + question-budget evidence)"
    },
    "cost": {
      "type": "object",
      "properties": {
        "tokens_in": { "type": "integer", "minimum": 0 },
        "tokens_out": { "type": "integer", "minimum": 0 },
        "wall_clock_min": { "type": "number", "minimum": 0 },
        "retries_used": { "type": "integer", "minimum": 0 }
      }
    },
    "depth": {
      "type": "string",
      "enum": ["minimal", "standard", "comprehensive"]
    },
    "request_classification": {
      "type": "object",
      "properties": {
        "clarity": { "type": "string", "enum": ["Clear", "Vague", "Incomplete"] },
        "type": {
          "type": "string",
          "enum": ["New Feature", "Bug Fix", "Refactoring", "Upgrade", "Migration", "Enhancement", "New Project"]
        },
        "scope": {
          "type": "string",
          "enum": ["Single File", "Single Component", "Multiple Components", "System-wide", "Cross-system"]
        },
        "complexity": {
          "type": "string",
          "enum": ["Trivial", "Simple", "Moderate", "Complex"]
        }
      }
    },
    "needs_user_input": {
      "type": "boolean",
      "description": "True if clarifying-questions gate is open"
    },
    "questions_artifact_path": {
      "type": "string",
      "description": "Path to questions file when needs_user_input=true"
    },
    "emitted_knowledge": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "title", "body"],
        "properties": {
          "kind": { "type": "string", "enum": ["pattern", "adr", "antipattern", "lesson"] },
          "title": { "type": "string", "minLength": 1 },
          "body": { "type": "string", "minLength": 1 },
          "tags": { "type": "array", "items": { "type": "string" }, "default": [] },
          "related_artifacts": { "type": "array", "items": { "type": "string" }, "default": [] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.8 }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "conflicts_detected": { "type": "array", "default": [] },
    "locks_to_release": { "type": "array", "items": { "type": "string" }, "default": [] }
  },
  "additionalProperties": false
}
