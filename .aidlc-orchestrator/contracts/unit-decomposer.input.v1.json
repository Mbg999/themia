{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "unit-decomposer.input.v1",
  "title": "Unit Decomposer — Input Contract (v1)",
  "type": "object",
  "required": ["run_id", "stage_id", "user_request", "predecessor_artifacts", "units", "skills_required", "skill_paths_resolved"],
  "properties": {
    "run_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "stage_id": { "const": "unit-decomposer" },
    "user_request": { "type": "string", "minLength": 1 },
    "predecessor_artifacts": { "type": "array", "items": { "type": "string" }, "minItems": 1, "description": "Must include execution-plan.md" },
    "units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "depends_on": { "type": "array", "items": { "type": "string" } }
        }
      },
      "minItems": 1,
      "description": "Copied from workflow-planner output"
    },
    "skills_required": { "type": "array", "items": { "type": "string" }, "minItems": 2, "default": ["using-agent-skills", "planning-and-task-breakdown"] },
    "skill_paths_resolved": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "budget": { "type": "object" },
    "gates": { "type": "array", "items": { "type": "string" }, "default": ["require_human_approval"] },
    "context_pointers": { "type": "array", "items": { "type": "string" }, "default": [] },
    "locks_required": { "type": "array", "items": { "type": "string" }, "default": [] },
    "model_override": {
      "type": "string",
      "enum": ["sonnet", "opus", "haiku"],
      "description": "Model to use for this stage. Overrides tool default. Set by orchestrator from budgets/default.yaml."
    }
  },
  "additionalProperties": false
}
