{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "reverse-engineer.input.v1",
  "title": "Reverse Engineer — Input Contract (v1)",
  "type": "object",
  "required": ["run_id", "stage_id", "user_request", "predecessor_artifacts", "workspace_state", "skills_required", "skill_paths_resolved"],
  "properties": {
    "run_id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "stage_id": { "const": "reverse-engineer" },
    "user_request": { "type": "string", "minLength": 1 },
    "predecessor_artifacts": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "workspace_state": {
      "type": "object",
      "properties": {
        "project_type": { "type": "string", "description": "Type of project (greenfield, legacy, monorepo, etc.)" },
        "existing_code": { "type": "string", "description": "Description of existing codebase" },
        "next_phase": { "type": "string", "description": "Next phase recommendation from workspace-scout" },
        "tech_stack_summary": { "type": "string", "description": "Detected technology stack summary" },
        "legacy_patterns": { "type": "array", "items": { "type": "string" }, "description": "Patterns detected in legacy code" }
      },
      "description": "Workspace state snapshot, sourced from workspace-scout output"
    },
    "skills_required": { "type": "array", "items": { "type": "string" }, "minItems": 1, "default": ["using-agent-skills"] },
    "skill_paths_resolved": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "budget": { "type": "object" },
    "gates": { "type": "array", "items": { "type": "string" }, "default": [] },
    "context_pointers": { "type": "array", "items": { "type": "string" }, "default": [] },
    "locks_required": { "type": "array", "items": { "type": "string" }, "default": [] },
    "model_override": {
      "type": "string",
      "enum": ["sonnet", "opus", "haiku"],
      "description": "Model to use for this stage. Overrides tool default. Set by orchestrator from budgets/default.yaml."
    }
  },
  "additionalProperties": false
}
