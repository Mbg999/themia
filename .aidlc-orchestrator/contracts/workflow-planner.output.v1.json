{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "workflow-planner.output.v1",
  "title": "Workflow Planner — Output Contract (v1)",
  "type": "object",
  "required": ["status", "artifacts", "audit_entries", "skill_compliance", "units", "task_count", "unit_count", "mermaid_validated"],
  "properties": {
    "status": { "type": "string", "enum": ["complete", "blocked", "failed", "needs_human"] },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind"],
        "properties": {
          "path": { "type": "string" },
          "kind": { "type": "string", "enum": ["plan"] },
          "hash": { "type": "string" }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "audit_entries": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
    "skill_compliance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["skill", "status", "evidence"],
        "properties": {
          "skill": { "type": "string" },
          "status": { "type": "string", "enum": ["PASS", "FAIL", "N/A"] },
          "evidence": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      },
      "minItems": 3,
      "description": "Must contain entries for using-agent-skills, planning-and-task-breakdown, and requirements-intelligence (plan-stage variant — pre-mortem on plan artifact). The requirements-intelligence entry may be status: N/A with evidence='trivial plan: skipped per SKILL.md plan-stage variant rule' when plan is single-unit AND every task has ≥2 acceptance criteria."
    },
    "cost": { "type": "object" },
    "units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "description": { "type": "string" },
          "depends_on": { "type": "array", "items": { "type": "string" }, "default": [] }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "task_count": { "type": "integer", "minimum": 1 },
    "unit_count": { "type": "integer", "minimum": 1 },
    "depth": { "type": "string", "enum": ["minimal", "standard", "comprehensive"] },
    "mermaid_validated": { "type": "boolean" },
    "emitted_knowledge": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "title", "body"],
        "properties": {
          "kind": { "type": "string", "enum": ["pattern", "adr", "antipattern", "lesson"] },
          "title": { "type": "string", "minLength": 1 },
          "body": { "type": "string", "minLength": 1 },
          "tags": { "type": "array", "items": { "type": "string" }, "default": [] },
          "related_artifacts": { "type": "array", "items": { "type": "string" }, "default": [] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.8 }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "conflicts_detected": { "type": "array", "default": [] },
    "locks_to_release": { "type": "array", "items": { "type": "string" }, "default": [] }
  },
  "additionalProperties": false
}
