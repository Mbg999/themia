# Thermia backend environment variables
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.

# Set to "local" for local development via SSH tunnel, "production" for direct DB access.
THERMIA_ENV=production

# Production path: direct PostgreSQL connection URL
DATABASE_URL=postgresql://user:password@host:5432/thermia

# Local path: SSH tunnel settings (used when THERMIA_ENV=local)
SSH_HOST=bastion.example.com
SSH_USER=ubuntu
SSH_PASSWORD=your_ssh_password_here
SSH_REMOTE_BIND_PORT=5432

# Local path: database credentials (used when THERMIA_ENV=local)
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=thermia
