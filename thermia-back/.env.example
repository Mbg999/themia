# Thermia backend environment variables
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.

# Set to "local" for local development via SSH tunnel, "production" for direct DB access.
THERMIA_ENV=production

# Production path: direct PostgreSQL connection URL
DATABASE_URL=postgresql://user:password@host:5432/thermia

# Local path: SSH tunnel settings (used when THERMIA_ENV=local)
SSH_HOST=bastion.example.com
SSH_USER=ubuntu
SSH_PASSWORD=your_ssh_password_here
SSH_REMOTE_BIND_PORT=5432

# Local path: database credentials (used when THERMIA_ENV=local)
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=thermia

# ---------------------------------------------------------------------------
# Cohere API keys — JSON array form (recommended for multi-key fallback)
# ---------------------------------------------------------------------------
# (a) Legacy single-key fallback: if COHERE_API_KEYS is not set but
#     COHERE_API_KEY is, the pool treats it as a 1-element pool and emits
#     a WARN log recommending migration to the array form.
#
# (b) At least one key is required (FR-6): the ingest pipeline and query API
#     will refuse to start if neither COHERE_API_KEYS nor COHERE_API_KEY
#     is present, raising a ValueError naming the missing variable.
#
# (c) Optional cool-down window override (default: 2592000 s = 30 days for
#     Cohere, matching the monthly Trial-key reset cycle):
#       COHERE_KEY_COOLDOWN_SECONDS=2592000
#
COHERE_API_KEYS='["your_cohere_api_key_here"]'
# For multi-key fallback add more keys, e.g.:
# COHERE_API_KEYS='["primary_key","secondary_key"]'

# ---------------------------------------------------------------------------
# Groq API keys — JSON array form (recommended for multi-key fallback)
# ---------------------------------------------------------------------------
# (a) Legacy single-key fallback: if GROQ_API_KEYS is not set but
#     GROQ_API_KEY is, the pool treats it as a 1-element pool and emits
#     a WARN log recommending migration to the array form.
#
# (b) At least one key is required (FR-6): the query API will refuse to
#     start if neither GROQ_API_KEYS nor GROQ_API_KEY is present.
#
# (c) Optional cool-down window override (default: 86400 s = 1 day for Groq,
#     matching the daily token reset cycle):
#       GROQ_KEY_COOLDOWN_SECONDS=86400
#
GROQ_API_KEYS='["your_groq_api_key_here"]'
# For multi-key fallback add more keys, e.g.:
# GROQ_API_KEYS='["primary_key","secondary_key"]'

# Retrieval API — Bearer token for POST /analyze
# REQUIRED: must be at least 16 characters. The application refuses to start
# if API_KEY is absent or shorter than 16 chars. Set this even for local dev.
# Example: API_KEY=dev-token-local-1234
API_KEY=your-dev-token-here-16chars

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:4200
